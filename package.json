{
  "name": "@phamyqb/mac-cleaner",
  "version": "1.2.0",
  "description": "Interactive macOS storage cleanup CLI + RAM monitor GUI",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mac-cleaner": "index.js"
  },
  "files": [
    "index.js",
    "src/",
    "gui/",
    "dist/renderer/"
  ],
  "scripts": {
    "start": "node index.js",
    "gui": "npm run build:renderer && node index.js --gui",
    "build:renderer": "vite build",
    "prepack": "npm run build:renderer",
    "test": "node --test"
  },
  "dependencies": {
    "@inquirer/prompts": "^3.3.0",
    "chalk": "^5.3.0",
    "electron": "^32.3.3",
    "ora": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21"
  }
}
